@model SettingsViewModel

@{
    ViewData["Title"] = "Settings";
}

<section class="page-grid settings-page">
    <div class="app-card app-card--hero">
        <h1 class="page-title">Settings</h1>
        <p class="page-subtitle">Choose translations and your preferred time zone.</p>

        <form class="settings-form" asp-controller="Home" asp-action="SaveSettings" method="post">
            @if(Model.EnglishTranslations != null)
            {
                @await Html.PartialAsync("TranslationPartial", @Model.EnglishTranslations)
            }
            @if(Model.GermanTranslations != null)
            {
                @await Html.PartialAsync("TranslationPartial", @Model.GermanTranslations)
            }
            @if(Model.TimeZones != null)
            {
                <div class="settings-field">
                    <label class="field-label" for="timezone">Time Zone</label>
                    <select id="timezone" name="timezone" class="app-control" asp-for="SelectedTimeZone"
                            asp-items="@(new SelectList(@Model.TimeZones, "Id", "Name"))">
                    </select>
                </div>
            }

            <button type="submit" class="btn app-btn-primary">Save</button>
        </form>
    </div>
</section>
